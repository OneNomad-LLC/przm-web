# ── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string. Used by both Drizzle (node-postgres, full SQL
# access) and the existing Neon HTTP driver (src/lib/db.ts).
DATABASE_URL=postgresql://user:password@host:5432/przm_web

# ── Auth (better-auth) ────────────────────────────────────────────────────────
# Random 32+ byte secret. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_me_generate_with_openssl_rand_base64_32

# The canonical URL of this deployment (no trailing slash).
# In production: https://przm.sh or https://app.przm.sh
BETTER_AUTH_URL=http://localhost:3000

# Exposed to the browser for the auth client.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at https://github.com/settings/applications/new
# Callback URL: <BETTER_AUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Stripe ────────────────────────────────────────────────────────────────────
# Live and test keys from https://dashboard.stripe.com/apikeys
# Use sk_test_... locally; sk_live_... in production only.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public URL used to build Checkout success/cancel return URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe Product Price IDs ──────────────────────────────────────────────────
# Create products/prices in the Stripe dashboard (test mode), then paste IDs.
# Run `pnpm stripe:seed` to create them automatically in your test account.
#
# Solo — $19/seat/mo | $190/seat/yr (2 months free)
STRIPE_PRICE_SOLO_MONTH=price_...
STRIPE_PRICE_SOLO_YEAR=price_...
#
# Team — $25/seat/mo | $250/seat/yr (5-seat min)
STRIPE_PRICE_TEAM_MONTH=price_...
STRIPE_PRICE_TEAM_YEAR=price_...
#
# Business — $59/seat/mo | $590/seat/yr (25-seat min)
STRIPE_PRICE_BUSINESS_MONTH=price_...
STRIPE_PRICE_BUSINESS_YEAR=price_...
#
# Business Pilot — $2,070 one-time, 10 seats, 90 days
# metadata.is_pilot = "true" must be set on the PaymentIntent (done in checkout.ts)
STRIPE_PRICE_PILOT=price_...
#
# Self-Hosted Departmental — $25,000/yr flat
STRIPE_PRICE_SELF_HOSTED_DEPARTMENTAL_YEAR=price_...
#
# Self-Hosted Division — $60,000/yr flat
STRIPE_PRICE_SELF_HOSTED_DIVISION_YEAR=price_...
#
# Self-Hosted Enterprise — $120,000/yr flat
STRIPE_PRICE_SELF_HOSTED_ENTERPRISE_YEAR=price_...
#
# Overage meters (Task #15 will wire the actual usage reporting)
# queries: $0.50 per 1,000 queries
STRIPE_PRICE_QUERIES_METER=price_...
# extractor tokens: $2.00 per 1,000,000 tokens
STRIPE_PRICE_EXTRACTOR_TOKENS_METER=price_...

# ── Resend ────────────────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
# From address: noreply@przm.sh (verify the domain in Resend first).
RESEND_API_KEY=re_...

# ── przm-access admin API ─────────────────────────────────────────────────────
# Server-side only — never expose to the browser.
# The base URL of the przm-access service (no trailing slash).
PRZM_ACCESS_BASE_URL=https://access.przm.sh

# Operator key for the przm-access admin API (Bearer token).
# Generated in the przm-access service configuration.
PRZM_ACCESS_ADMIN_KEY=przm_access_operator_key_here

# ── Legacy / existing ─────────────────────────────────────────────────────────
# Used by the existing admin inbox routes (/admin/*, /api/admin/*).
ADMIN_PASSWORD=replace_with_a_strong_password
