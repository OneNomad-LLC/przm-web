# ── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string. Used by both Drizzle (node-postgres, full SQL
# access) and the existing Neon HTTP driver (src/lib/db.ts).
DATABASE_URL=postgresql://user:password@host:5432/przm_web

# ── Auth (better-auth) ────────────────────────────────────────────────────────
# Random 32+ byte secret. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_me_generate_with_openssl_rand_base64_32

# The canonical URL of this deployment (no trailing slash).
# In production: https://przm.sh or https://app.przm.sh
BETTER_AUTH_URL=http://localhost:3000

# Exposed to the browser for the auth client.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at https://github.com/settings/applications/new
# Callback URL: <BETTER_AUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Stripe ────────────────────────────────────────────────────────────────────
# Live and test keys from https://dashboard.stripe.com/apikeys
# Use sk_test_... locally; sk_live_... in production only.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend ────────────────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
# From address: noreply@przm.sh (verify the domain in Resend first).
RESEND_API_KEY=re_...

# ── przm-access admin API ─────────────────────────────────────────────────────
# Server-side only — never expose to the browser.
# The base URL of the przm-access service (no trailing slash).
PRZM_ACCESS_BASE_URL=https://access.przm.sh

# Operator key for the przm-access admin API (Bearer token).
# Generated in the przm-access service configuration.
PRZM_ACCESS_ADMIN_KEY=przm_access_operator_key_here

# ── Legacy / existing ─────────────────────────────────────────────────────────
# Used by the existing admin inbox routes (/admin/*, /api/admin/*).
ADMIN_PASSWORD=replace_with_a_strong_password
